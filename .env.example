# =============================================================================
# HOEM — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to Git
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_USER=hoem
DB_PASSWORD=changeme_use_a_strong_password

# -----------------------------------------------------------------------------
# JWT
# Minimum 32 characters. Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Resend (transactional email)
# Get your key at: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_changeme

# -----------------------------------------------------------------------------
# ESIOS API (Red Eléctrica Española — electricity prices)
# Get your token at: https://api.esios.ree.es/
# -----------------------------------------------------------------------------
ESIOS_TOKEN=changeme

# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# Create a tunnel at: https://one.dash.cloudflare.com/
# -----------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=changeme

# -----------------------------------------------------------------------------
# PostHog (product analytics)
# Get your key at: https://posthog.com/
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=phc_changeme
POSTHOG_HOST=https://eu.posthog.com

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
APP_BASE_URL=http://localhost:3000
